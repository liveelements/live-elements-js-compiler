component A < Element{
    number x: 20
    get x(){ return Element.getProperty('x') }
    set x(val:any){ Element.setProperty('x', val) }

    get y(){ return this._y }
    set y(val:any){ this._y = val }

    number z: 30
    get z(){ return Element{} }
    set z(val:any){ Element{ number x: val } }
}
