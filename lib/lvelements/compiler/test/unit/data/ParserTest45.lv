component X{
    any x: {
        return this.y.value + this.z.value
    }
    any y: this.z.a + this.z.b
    z: this.m.getValue()
    w: this.getValue()

    t: T{
        any x: {
            var i = this.y
            return i.length
        }
        any y: this.z.a + this.z.b
        z: this.m.getValue()
    }
}
