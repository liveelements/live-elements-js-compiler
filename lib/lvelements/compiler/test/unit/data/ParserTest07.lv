component default < Container{
    number a : 20
    number b : 30
    number c : 20

    Element{
        number x : parent.a + parent.b
    }

    Element{
        number y : {
            function a(){
                return parent.a
            }

            return a() + parent.b
        }
    }

    Element{
        number z : {
            var result = 0
            for ( var i = 0; i < 3; ++i ){
                result += parent.a
            }
            for (const it of [0, 1, 2]) {
                result += it
            }
            for ( const [key, value] of Object.entries(this) ) {
                result += key + value
            }
            if ( parent.b > 0 )
                result += parent.b
            return result
        }
    }

    Element{
        number w : {
            var result = 0;

            class A{
                constructor(){
                    this.field = parent.a
                }
            }

            result += (new A()).field;
            return result
        }
    }

}